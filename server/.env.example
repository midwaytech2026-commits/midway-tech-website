# Server port — Render sets this automatically, leave as 5000 for local dev.
PORT=5000

# MongoDB Atlas connection string.
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGO_URI=your_mongodb_atlas_connection_string

# The deployed Vercel frontend URL — used for CORS allow-list.
# No trailing slash.
CLIENT_URL=https://your-frontend-domain.vercel.app
